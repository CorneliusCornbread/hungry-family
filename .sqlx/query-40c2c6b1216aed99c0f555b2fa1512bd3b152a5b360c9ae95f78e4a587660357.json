{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT a.account_id, a.user_id, a.username\n        FROM sessions s\n        JOIN accounts a ON a.account_id = s.account_id\n        WHERE s.token = $1\n          AND s.expires_at > NOW()\n        ",
